.icon-card img{width:48px;height:48px;object-fit:contain;border-radius:8px;flex-shrink:0}
.icon-card .info{flex:1;min-width:0}
.icon-card .info .nm{font-size:14px;font-weight:600;color:#2b2d3a;margin-bottom:2px;word-break:break-all}
.icon-card .info .meta{font-size:11px;color:#6b6f86}
.icon-card .info input{width:100%;padding:6px 10px;border-radius:10px;border:1px solid rgba(140,160,210,.28);background:rgba(255,255,255,.78);color:#2b2d3a;font-size:13px;outline:none;transition:.2s;margin-bottom:4px}
.icon-card .info input:focus{border-color:rgba(124,107,255,.55);box-shadow:0 0 0 3px rgba(124,107,255,.12)}
.icon-card .actions{display:flex;gap:6px;flex-shrink:0}
