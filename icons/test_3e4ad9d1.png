#!/usr/bin/env python3
"""
embytb - Emby 图标上传站 (ACG Edition)
"""
import os, json, base64, io, hashlib, hmac, time, re, urllib.request, urllib.error, secrets
from http.server import HTTPServer, BaseHTTPRequestHandler
from urllib.parse import urlparse, parse_qs

TOKEN_FILE="/opt/gh_token.txt"
OWNER = "buleeee1111"
REPO = "embytb"
ICON_DIR = "icons"
INDEX_FILE = "Emby-Icon.json"
MAX_SIZE = 5 * 1024 * 1024
ALLOWED_EXT = {".png", ".jpg", ".jpeg", ".gif", ".webp", ".svg", ".heic", ".heif", ".bmp", ".ico"}
PORT = 3456
ADMIN_USER = "mama"
ADMIN_PASS = "061029"
_admin_sessions = set()
SHORT_DOMAIN = "emby.0000699.xyz"

with open(TOKEN_FILE) as f:
    GITHUB_TOKEN = f.read().strip()

def gh_api(method, path, data=None, raw=False):
    url = f"https://api.github.com{path}"
    headers = {
        "Authorization": f"token {GITHUB_TOKEN}",
        "Accept": "application/vnd.github+json",
        "User-Agent": "embytb/1.0",
    }
    if data is not None:
        headers["Content-Type"] = "application/json"
        body = json.dumps(data).encode()
        req = urllib.request.Request(url, data=body, headers=headers, method=method)
    else:
        req = urllib.request.Request(url, headers=headers, method=method)
    try:
        resp = urllib.request.urlopen(req, timeout=15)
        if raw:
            return resp.read()
        return json.loads(resp.read())
    except urllib.error.HTTPError as e:
        err = e.read().decode()
        return {"_error": f"HTTP {e.code}", "_detail": err[:500]}

def get_index():
    r = gh_api("GET", f"/repos/{OWNER}/{REPO}/contents/{INDEX_FILE}")
    if "_error" in r or not r.get("content"):
        return {"name": "embytb 图标库", "icons": []}, None
    content = base64.b64decode(r["content"]).decode()
    return json.loads(content), r["sha"]

def save_index(data, sha):
    content = json.dumps(data, indent=2, ensure_ascii=False)
    r = gh_api("PUT", f"/repos/{OWNER}/{REPO}/contents/{INDEX_FILE}", {
        "message": "update icon index",
        "content": base64.b64encode(content.encode()).decode(),
        "sha": sha,
        "branch": "main",
    })
    return "_error" not in r

def upload_to_github(filename, file_data):
    path = f"{ICON_DIR}/{filename}"
    content_b64 = base64.b64encode(file_data).decode()
    existing = gh_api("GET", f"/repos/{OWNER}/{REPO}/contents/{path}")
    sha = existing.get("sha") if "_error" not in existing else None
    r = gh_api("PUT", f"/repos/{OWNER}/{REPO}/contents/{path}", {
        "message": f"add icon: {filename}",
        "content": content_b64,
        "branch": "main",
    })
    if sha:
        r["sha"] = sha
    return r

def get_cdn_url(filename):
    return f"https://raw.githubusercontent.com/{OWNER}/{REPO}/main/{ICON_DIR}/{filename}"

def get_short_url(code):
    return f"https://{SHORT_DOMAIN}/i/{code}"

def generate_short_code(file_data):
    return hashlib.md5(file_data).hexdigest()[:8]


class EmbyTBHandler(BaseHTTPRequestHandler):

    def _send_json(self, data, status=200):
        self.send_response(status)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Access-Control-Allow-Origin", "*")
        self.end_headers()
        self.wfile.write(json.dumps(data, ensure_ascii=False).encode())

    def _send_html(self, html, status=200):
        self.send_response(status)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.end_headers()
        self.wfile.write(html.encode())

    def _send_error(self, msg, status=400):
        self._send_json({"error": msg}, status)

    def _read_post_body(self):
        length = int(self.headers.get("Content-Length", 0))
        if length > MAX_SIZE * 2:
            return None
        return self.rfile.read(length)

    def _is_admin(self):
        c = self.headers.get("Cookie", "")
        for part in c.split(";"):
            p = part.strip()
            if p.startswith("admin_session="):
                tok = p.split("=", 1)[1].strip()
                return tok in _admin_sessions
        return False

    def log_message(self, format, *args):
        print(f"[{self.log_date_time_string()}] {args[0]} {args[1]} {args[2]}")

    def do_OPTIONS(self):
        self.send_response(204)
        self.send_header("Access-Control-Allow-Origin", "*")
        self.send_header("Access-Control-Allow-Methods", "GET, POST, OPTIONS")
        self.send_header("Access-Control-Allow-Headers", "Content-Type")
        self.end_headers()

    def do_GET(self):
        parsed = urlparse(self.path)
        path = parsed.path

        if path == "/api/icons":
            data, _ = get_index()
            for icon in data.get("icons", []):
                if "url" not in icon and "filename" in icon:
                    icon["url"] = get_cdn_url(icon["filename"])
                if icon.get("short_code"):
                    icon["short_url"] = get_short_url(icon["short_code"])
            self._send_json(data)

        elif path == "/icons-all.json":
            data, _ = get_index()
            result = {"name": data.get("name", "embytb"), "description": "", "icons": []}
            for icon in data.get("icons", []):
                url = icon.get("url") or get_cdn_url(icon["filename"])
                cat = icon.get("shape", "square")
                result["icons"].append({"name": icon.get("name", ""), "url": url, "category": cat})
            self._send_json(result)

        elif path == "/api/stats":
            data, _ = get_index()
            self._send_json({
                "total": len(data.get("icons", [])),
                "name": data.get("name", ""),
            })

        elif path == "/" or path == "":
            self._send_html(FRONTEND_HTML)

        elif path.startswith("/i/"):
            code = path[3:]
            if not code or "/" in code:
                self._send_error("Invalid code", 400)
                return
            data, _ = get_index()
            target = None
            for icon in data.get("icons", []):
                if icon.get("short_code") == code:
                    target = icon
                    break
            if not target:
                self._send_error("Not found", 404)
                return
            redirect_url = target.get("url") or get_cdn_url(target["filename"])
            self.send_response(302)
            self.send_header("Location", redirect_url)
            self.end_headers()

        elif path == "/admin/login":
            self._send_html(ADMIN_LOGIN_HTML)

        elif path == "/admin/" or path == "/admin":
            if not self._is_admin():
                self.send_response(302)
                self.send_header("Location", "/admin/login")
                self.end_headers()
                return
            self._send_html(ADMIN_DASHBOARD_HTML)

        elif path == "/admin/logout":
            c = self.headers.get("Cookie", "")
            for part in c.split(";"):
                p = part.strip()
                if p.startswith("admin_session="):
                    tok = p.split("=", 1)[1].strip()
                    _admin_sessions.discard(tok)
            self.send_response(302)
            self.send_header("Location", "/admin/login")
            self.send_header("Set-Cookie", "admin_session=; Path=/; Max-Age=0")
            self.end_headers()

        else:
            self._send_error("Not found", 404)

    def do_POST(self):
        parsed = urlparse(self.path)
        path = parsed.path

        if path == "/api/upload":
            self._handle_upload()
        elif path == "/admin/login":
            self._handle_admin_login()
        elif path == "/admin/delete":
            if not self._is_admin():
                self._send_error("Unauthorized", 401)
                return
            self._handle_admin_delete()
        elif path == "/admin/rename":
            if not self._is_admin():
                self._send_error("Unauthorized", 401)
                return
            self._handle_admin_rename()
        else:
            self._send_error("Not found", 404)

    def _handle_upload(self):
        content_type = self.headers.get("Content-Type", "")
        if "multipart/form-data" not in content_type:
            self._send_error("请使用 multipart/form-data 上传")
            return
        boundary = content_type.split("boundary=")[1].strip()
        body = self._read_post_body()
        if body is None:
            self._send_error("文件太大")
            return
        parts = body.split(b"--" + boundary.encode())
        file_data = None
        filename = None
        icon_name = None
        icon_shape = "square"
        for part in parts:
            if b"Content-Disposition" not in part:
                continue
            disp_lines = [l for l in part.split(b"\r\n") if l.strip()]
            disp = disp_lines[0] if disp_lines else b""
            if b'name="icon_name"' in disp:
                body_start = part.find(b"\r\n\r\n")
                if body_start > 0:
                    val = part[body_start + 4:].strip()
                    val = val.split(b"\r\n")[0].strip()
                    icon_name = val.decode("utf-8", errors="replace").strip()
                continue
            if b'name="shape"' in disp:
                body_start = part.find(b"\r\n\r\n")
                if body_start > 0:
                    val = part[body_start + 4:].strip()
                    val = val.split(b"\r\n")[0].strip()
                    icon_shape = val.decode("utf-8", errors="replace").strip() or "square"
                continue
            if b'name="file"' in disp or b'name="image"' in disp:
                m = re.search(rb'filename="(.+?)"', part)
                if m:
                    raw_name = m.group(1).decode()
                    filename = re.sub(r'[^\w\.-]', '', raw_name)
                body_start = part.find(b"\r\n\r\n")
                if body_start > 0:
                    file_data = part[body_start + 4:]
                    file_data = file_data.rstrip(b"\r\n").rstrip(b"-")
                continue
        if not file_data or not filename:
            self._send_error("未找到上传文件")
            return
        if len(file_data) > MAX_SIZE:
            self._send_error(f"文件太大 (最大 {MAX_SIZE // 1024 // 1024}MB)")
            return
        ext = os.path.splitext(filename)[1].lower()
        if ext not in ALLOWED_EXT:
            self._send_error(f"不支持的文件格式: {ext}")
            return
        file_hash = hashlib.md5(file_data).hexdigest()[:8]
        short_code = file_hash
        safe_name = re.sub(r'[^\w\.-]', '', filename)
        name_part = os.path.splitext(safe_name)[0]
        final_filename = f"{name_part}_{file_hash}{ext}"
        if not icon_name:
            icon_name = name_part
        result = upload_to_github(final_filename, file_data)
        if "_error" in result:
            self._send_error(f"上传失败: {result['_error']}")
            return
        index_data, index_sha = get_index()
        index_data["icons"] = [i for i in index_data.get("icons", [])
                               if i.get("name") != icon_name or i.get("filename") != final_filename]
        index_data["icons"].append({
            "name": icon_name,
            "filename": final_filename,
            "short_code": short_code,
            "shape": icon_shape,
            "uploaded_at": time.strftime("%Y-%m-%d %H:%M:%S"),
        })
        if not save_index(index_data, index_sha):
            print("Index update failed, but file uploaded")
        cdn_url = get_cdn_url(final_filename)
        gh_url = f"https://raw.githubusercontent.com/{OWNER}/{REPO}/main/{ICON_DIR}/{final_filename}"
        all_links = []
        for ic in index_data.get("icons", []):
            ic_url = get_short_url(ic.get("short_code", "")) if ic.get("short_code") else get_cdn_url(ic["filename"])
            all_links.append({"name": ic["name"], "url": ic_url, "shape": ic.get("shape", "square")})
        md_links = "\n".join([f"![{l['name']}]({l['url']})" for l in all_links])
        txt_links = "\n".join([l["url"] for l in all_links])
        self._send_json({
            "success": True,
            "filename": final_filename,
            "name": icon_name,
            "shape": icon_shape,
            "short_code": short_code,
            "short_url": get_short_url(short_code),
            "cdn_url": cdn_url,
            "raw_url": gh_url,
            "all_icons": all_links,
            "all_markdown": md_links,
            "all_links": txt_links,
        }, 201)

    def _handle_admin_login(self):
        length = int(self.headers.get("Content-Length", 0))
        body = self.rfile.read(length).decode()
        params = parse_qs(body)
        user = params.get("username", [""])[0]
        pw = params.get("password", [""])[0]
        if user == ADMIN_USER and pw == ADMIN_PASS:
            tok = secrets.token_hex(16)
            _admin_sessions.add(tok)
            self.send_response(302)
            self.send_header("Location", "/admin/")
            self.send_header("Set-Cookie", f"admin_session={tok}; Path=/; Max-Age=86400")
            self.end_headers()
        else:
            self.send_response(302)
            self.send_header("Location", "/admin/login?e=1")
            self.end_headers()

    def _handle_admin_delete(self):
        length = int(self.headers.get("Content-Length", 0))
        body = self.rfile.read(length).decode()
        params = parse_qs(body)
        sc = params.get("short_code", [""])[0]
        if not sc:
            self._send_json({"error": "missing short_code"}, 400)
            return
        data, sha = get_index()
        found = None
        for ic in data.get("icons", []):
            if ic.get("short_code") == sc:
                found = ic
                break
        if not found:
            self._send_json({"error": "not found"}, 404)
            return
        data["icons"] = [ic for ic in data["icons"] if ic.get("short_code") != sc]
        if not save_index(data, sha):
            self._send_json({"error": "save index failed"}, 500)
            return
        try:
            fn = found.get("filename", "")
            if fn:
                r = gh_api("GET", f"/repos/{OWNER}/{REPO}/contents/{ICON_DIR}/{fn}")
                if "_error" not in r and r.get("sha"):
                    gh_api("DELETE", f"/repos/{OWNER}/{REPO}/contents/{ICON_DIR}/{fn}", {
                        "message": f"delete icon: {fn}",
                        "sha": r["sha"],
                        "branch": "main",
                    })
        except:
            pass
        self._send_json({"success": True})

    def _handle_admin_rename(self):
        length = int(self.headers.get("Content-Length", 0))
        body = self.rfile.read(length).decode()
        params = parse_qs(body)
        sc = params.get("short_code", [""])[0]
        new_name = params.get("name", [""])[0]
        if not sc or not new_name:
            self._send_json({"error": "missing params"}, 400)
            return
        data, sha = get_index()
        for ic in data.get("icons", []):
            if ic.get("short_code") == sc:
                ic["name"] = new_name
                break
        else:
            self._send_json({"error": "not found"}, 404)
            return
        if save_index(data, sha):
            self._send_json({"success": True})
        else:
            self._send_json({"error": "save failed"}, 500)


