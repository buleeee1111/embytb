.toast.show{opacity:1}
.empty{text-align:center;padding:40px;color:#6b6f86}
</style></head>
<body>
<div class="header">
<h1>📦 embytb 管理后台</h1>
<div><a href="/admin/logout">退出</a><a href="/" target="_blank">前台</a></div>
</div>
<div class="container">
<div class="stats-box"><div class="num" id="totalCount">0</div><div class="label">图标总数</div></div>
<div class="search-box"><input type="text" id="search" placeholder="🔍 搜索图标..." oninput="filterIcons()"></div>
<div id="iconList" class="icon-list"></div>
</div>
<div class="toast" id="toast"></div>
<script>
var allIcons=[];
function showToast(m){var t=document.getElementById("toast");t.textContent=m;t.classList.add("show");setTimeout(function(){t.classList.remove("show")},2000)}
function loadIcons(){fetch("/api/icons").then(function(r){return r.json()}).then(function(d){allIcons=d.icons||[];document.getElementById("totalCount").textContent=allIcons.length;renderIcons(allIcons)})}
function renderIcons(icons){var el=document.getElementById("iconList");el.textContent="";if(!icons.length){var e=document.createElement("div");e.className="empty";e.textContent="暂无图标";el.appendChild(e);return}
for(var i=0;i<icons.length;i++){var ic=icons[i];var fn=ic.filename||"";var nm=ic.name||fn;var sc=ic.short_code||"";var su=ic.short_url||"";var cu=ic.url||(sc?"https://cdn.jsdelivr.net/gh/buleeee1111/embytb/icons/"+fn:"")
var card=document.createElement("div");card.className="icon-card"
var img=document.createElement("img");img.src=cu;img.alt=nm;img.onerror=function(){this.remove()};card.appendChild(img)
var inf=document.createElement("div");inf.className="info"
var inp=document.createElement("input");inp.id="rn-"+sc;inp.value=nm;inf.appendChild(inp)
var mt=document.createElement("div");mt.className="meta";mt.textContent="短码: "+sc+" | "+fn;inf.appendChild(mt)
card.appendChild(inf)
var act=document.createElement("div");act.className="actions"
var cb=document.createElement("button");cb.className="btn btn-copy";cb.textContent="📋";cb.onclick=function(u){return function(){navigator.clipboard.writeText(u).then(function(){showToast("已复制")})}}(su);act.appendChild(cb)
var sb=document.createElement("button");sb.className="btn btn-save";sb.textContent="改名";sb.onclick=function(c){return function(){var inp=document.getElementById("rn-"+c);if(!inp)return;var nm=inp.value.trim();if(!nm){showToast("名称不能为空");return}
var f=new URLSearchParams();f.set("short_code",c);f.set("name",nm);fetch("/admin/rename",{method:"POST",headers:{"Content-Type":"application/x-www-form-urlencoded"},body:f}).then(function(r){return r.json()}).then(function(d){if(d.success){showToast("已改名");loadIcons()}else{showToast("改名失败: "+d.error)}})}}(sc);act.appendChild(sb)
var db=document.createElement("button");db.className="btn btn-del";db.textContent="删除";db.onclick=function(c,n){return function(){if(!confirm("确定删除 "+n+" ？"))return
var f=new URLSearchParams();f.set("short_code",c);fetch("/admin/delete",{method:"POST",headers:{"Content-Type":"application/x-www-form-urlencoded"},body:f}).then(function(r){return r.json()}).then(function(d){if(d.success){showToast("已删除");loadIcons()}else{showToast("删除失败: "+d.error)}})}}(sc,nm);act.appendChild(db)
card.appendChild(act);el.appendChild(card)}}
function filterIcons(){var q=document.getElementById("search").value.toLowerCase();if(!q){renderIcons(allIcons);return}
var f=[];for(var i=0;i<allIcons.length;i++){var n=(allIcons[i].name||"").toLowerCase();var m=(allIcons[i].filename||"").toLowerCase();if(n.indexOf(q)>=0||m.indexOf(q)>=0)f.push(allIcons[i])}
renderIcons(f)}
loadIcons();
</script>
</body></html>"""

FRONTEND_HTML = """<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>embytb - Emby 图标库</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:ui-sans-serif,system-ui,-apple-system,"PingFang SC","Hiragino Sans GB","Microsoft YaHei",Arial,sans-serif;color:#2b2d3a;min-height:100vh;display:flex;justify-content:center;align-items:flex-start;padding:18px;
background-size:cover;background-position:center center;background-repeat:no-repeat;background-attachment:fixed}
.container{width:100%;max-width:680px;padding:28px 24px;border-radius:22px;background:rgba(255,255,255,.72);border:1px solid rgba(255,255,255,.55);box-shadow:0 18px 40px rgba(35,50,90,.12);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);position:relative;overflow:hidden;margin:10px auto}
.container::before{content:"";position:absolute;inset:-120px -120px auto auto;width:260px;height:260px;background:radial-gradient(circle at 30% 30%,rgba(255,107,214,.35),transparent 60%),radial-gradient(circle at 70% 60%,rgba(57,213,255,.28),transparent 55%),radial-gradient(circle at 40% 80%,rgba(124,107,255,.25),transparent 60%);transform:rotate(12deg);pointer-events:none}
h1{text-align:center;margin-bottom:16px;font-size:26px;letter-spacing:.5px;line-height:1.2;background:linear-gradient(90deg,#ff6bd6,#7c6bff,#39d5ff);-webkit-background-clip:text;background-clip:text;color:transparent;text-shadow:0 10px 22px rgba(124,107,255,.1);position:relative}
.subtitle{text-align:center;font-size:12px;color:#6b6f86;margin-bottom:16px;position:relative}

/* 分类按钮 */
.folder-grid{display:flex;gap:8px;margin-bottom:16px;justify-content:center;position:relative}
.folder-btn{padding:8px 20px;border-radius:16px;border:1px solid rgba(140,160,210,.28);background:rgba(255,255,255,.6);color:#6b6f86;font-size:14px;font-weight:600;cursor:pointer;transition:.2s;touch-action:manipulation}
.folder-btn:hover{background:rgba(124,107,255,.1);border-color:rgba(124,107,255,.4);color:#7c6bff}
.folder-btn.active{background:linear-gradient(90deg,#ff6bd6,#7c6bff);color:#fff;border-color:transparent;box-shadow:0 8px 20px rgba(124,107,255,.25)}

/* 上传区 */
.upload-area{border:2px dashed rgba(140,160,210,.28);border-radius:16px;padding:26px 20px;text-align:center;cursor:pointer;transition:.2s;background:rgba(255,255,255,.5);margin-bottom:16px;position:relative}
.upload-area:hover,.upload-area.dragover{border-color:rgba(124,107,255,.4);background:rgba(124,107,255,.05);transform:translateY(-1px)}
.upload-area .icon{font-size:36px;margin-bottom:4px}
.upload-area p{color:#6b6f86;font-size:14px}
.upload-area .hint{color:rgba(107,111,134,.65);font-size:11px;margin-top:2px}

/* 搜索 */
.search-bar{margin-bottom:16px;position:relative}
.search-bar input{width:100%;padding:11px 16px;border-radius:16px;border:1px solid rgba(140,160,210,.28);background:rgba(255,255,255,.78);color:#2b2d3a;font-size:14px;outline:none;transition:.2s}
.search-bar input:focus{border-color:rgba(124,107,255,.55);box-shadow:0 0 0 4px rgba(124,107,255,.16),0 10px 26px rgba(57,213,255,.1);transform:translateY(-1px)}
.search-bar input::placeholder{color:rgba(107,111,134,.65)}

/* 图标网格 */
.icon-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:12px;position:relative;margin-bottom:16px}
.icon-card{background:rgba(255,255,255,.65);border:1px solid rgba(140,160,210,.18);border-radius:16px;padding:12px 8px;text-align:center;cursor:pointer;transition:.2s;position:relative}
.icon-card:hover{border-color:rgba(124,107,255,.35);transform:translateY(-3px);box-shadow:0 12px 24px rgba(35,50,90,.1)}
.icon-card img{width:56px;height:56px;object-fit:contain;margin-bottom:6px;display:block;margin-left:auto;margin-right:auto}
.icon-card.square img{border-radius:6px}
.icon-card.circle img{border-radius:50%}
.icon-card .name{font-size:11px;color:#6b6f86;word-break:break-all;line-height:1.3;overflow:hidden;text-overflow:ellipsis;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical}
.icon-card .badge{position:absolute;top:4px;right:4px;background:linear-gradient(90deg,#3fb950,#2ea043);color:#fff;font-size:9px;padding:2px 6px;border-radius:8px;display:none;font-weight:600}
.icon-card .badge.show{display:block}

/* 加载/空态 */
.loading{text-align:center;padding:40px;color:#6b6f86;font-size:14px}
.empty{text-align:center;padding:40px;color:#6b6f86;font-size:14px}

/* Footer */
.footer{border-top:1px solid rgba(140,160,210,.2);padding:14px 0 4px;margin-top:6px;position:relative}
.footer-title{font-size:13px;font-weight:700;margin-bottom:8px;color:#6b6f86;background:linear-gradient(90deg,#ff6bd6,#7c6bff);-webkit-background-clip:text;background-clip:text;color:transparent;display:inline-block}
.footer-links{display:flex;flex-wrap:wrap;gap:4px 6px;margin-bottom:8px}
.footer-links a{color:#7c6bff;font-size:11px;text-decoration:none;padding:3px 8px;border:1px solid rgba(140,160,210,.2);border-radius:10px;white-space:nowrap;transition:.15s;background:rgba(255,255,255,.4)}
.footer-links a:hover{border-color:rgba(124,107,255,.4);background:rgba(124,107,255,.08);transform:translateY(-1px)}
.footer-bar{display:flex;align-items:center;gap:10px;font-size:11px;color:#6b6f86;flex-wrap:wrap}
.footer-bar strong{background:linear-gradient(90deg,#7c6bff,#39d5ff);-webkit-background-clip:text;background-clip:text;color:transparent}
.btn-footer-copy{background:linear-gradient(90deg,#7c6bff,#39d5ff);color:#fff;padding:5px 14px;border-radius:12px;border:none;cursor:pointer;font-size:11px;font-weight:600;transition:.15s;box-shadow:0 4px 12px rgba(124,107,255,.2)}
.btn-footer-copy:hover{transform:translateY(-1px);box-shadow:0 6px 16px rgba(124,107,255,.3)}
.footer-admin{color:#6b6f86;text-decoration:none;margin-left:auto;font-size:11px}
.footer-admin:hover{color:#7c6bff}

/* 上传弹窗 */
.upload-modal{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.35);align-items:center;justify-content:center;z-index:1000;backdrop-filter:blur(4px)}
.upload-modal.show{display:flex}
.upload-modal .panel{background:rgba(255,255,255,.92);backdrop-filter:blur(20px);border:1px solid rgba(255,255,255,.8);border-radius:22px;padding:28px 24px;width:90%;max-width:420px;box-shadow:0 24px 48px rgba(35,50,90,.15);position:relative}
.upload-modal .panel h2{font-size:20px;margin-bottom:16px;background:linear-gradient(90deg,#ff6bd6,#7c6bff,#39d5ff);-webkit-background-clip:text;background-clip:text;color:transparent}
.upload-modal .panel input[type=text]{width:100%;padding:11px 14px;border-radius:14px;border:1px solid rgba(140,160,210,.28);background:rgba(255,255,255,.8);color:#2b2d3a;font-size:14px;outline:none;margin-bottom:12px;transition:.2s}
.upload-modal .panel input[type=text]:focus{border-color:rgba(124,107,255,.55);box-shadow:0 0 0 4px rgba(124,107,255,.16)}
/* shape removed, use category buttons */
.actions{display:flex;gap:8px;justify-content:flex-end;margin-top:4px}
.btn{font-size:14px;padding:10px 20px;border-radius:14px;border:none;cursor:pointer;font-weight:600;transition:.15s}
.btn:hover{transform:translateY(-1px)}
.btn-primary{background:linear-gradient(90deg,#ff6bd6,#7c6bff,#39d5ff);color:#fff;box-shadow:0 8px 20px rgba(124,107,255,.2)}
.btn-secondary{background:rgba(140,160,210,.15);color:#6b6f86}
.btn-copy{background:linear-gradient(90deg,#3fb950,#2ea043);color:#fff;box-shadow:0 8px 20px rgba(63,185,80,.2)}
.upload-progress{display:none;text-align:center;padding:30px}
.upload-progress.show{display:block}
.upload-progress p{font-size:16px;color:#6b6f86;margin-bottom:8px}
.upload-result{display:none}
.upload-result.show{display:block}
.upload-result .preview-box{display:flex;align-items:center;gap:14px;padding:14px;background:rgba(255,255,255,.6);border-radius:14px;margin-bottom:12px;border:1px solid rgba(140,160,210,.15)}
.upload-result .preview-box img{width:48px;height:48px;object-fit:contain;border-radius:8px}
.upload-result .preview-box .info .nm{font-weight:600;font-size:14px;color:#2b2d3a}
.upload-result .preview-box .info .shp{color:#6b6f86;font-size:12px}
.upload-result .preview-box .info .url{color:#7c6bff;font-size:11px;word-break:break-all}
.upload-result .links-box{background:rgba(255,255,255,.5);border:1px solid rgba(140,160,210,.15);border-radius:12px;padding:12px;max-height:180px;overflow-y:auto;font-size:11px;font-family:monospace;white-space:pre-wrap;word-break:break-all;margin-bottom:12px;color:#2b2d3a}
.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:linear-gradient(90deg,#3fb950,#2ea043);color:#fff;padding:12px 28px;border-radius:16px;font-size:14px;font-weight:600;opacity:0;transition:.3s;pointer-events:none;z-index:999;box-shadow:0 8px 24px rgba(63,185,80,.3)}
.toast.show{opacity:1}
@media(max-width:480px){.container{padding:20px 16px;border-radius:18px}h1{font-size:22px}.icon-grid{grid-template-columns:repeat(auto-fill,minmax(90px,1fr));gap:8px}.icon-card img{width:44px;height:44px}.icon-card{padding:8px 6px}.folder-btn{padding:7px 14px;font-size:13px}}
</style>
</head>
<body>
<div class="container">
<h1>📦 embytb</h1>
<p class="subtitle">✨ Emby 图标上传站 · 点击卡片复制短链接</p>

<div class="folder-grid" id="folderGrid">
<button class="folder-btn active" data-category="all">✨ 全部</button>
<button class="folder-btn" data-category="circle">● 圆形</button>
<button class="folder-btn" data-category="square">■ 方形</button>
<button class="folder-btn" data-category="transparent">◇ 透明</button>
</div>

<div class="upload-area" id="uploadArea" onclick="openUploadModal()">
<div class="icon">📤</div>
<p>点击或拖拽上传图标</p>
<div class="hint">PNG / JPG / GIF / WebP / SVG · 最大 5MB</div>
</div>

<div class="search-bar"><input type="text" id="searchInput" placeholder="🔍 搜索图标..." oninput="filterIcons()"></div>

<div id="iconGrid" class="icon-grid"><div class="loading">🌸 加载中...</div></div>

<div class="footer">
<div class="footer-title">📋 全部图标聚合链接</div>
<div id="footerLinks" class="footer-links"><span class="loading" style="padding:0;color:#6b6f86;font-size:12px">加载中...</span></div>
<div class="footer-bar">
<span>共 <strong id="footerCount">0</strong> 个图标</span>
<button class="btn-footer-copy" onclick="copyFooterAll()">📋 复制全部</button>
<a href="/icons-all.json" class="footer-admin" target="_blank">📄 聚合 JSON</a>
<a href="/admin/" class="footer-admin">⚙️ 管理</a>
</div>
</div>
</div>

<div class="upload-modal" id="uploadModal">
<div class="panel">
<div id="uploadForm">
<h2>📤 上传图标</h2>
<input type="text" id="iconNameInput" placeholder="图标名称（可选）">
<!-- shape removed -->
<input type="file" id="fileInput" accept="image/*" style="display:none">
<div class="actions">
<button class="btn btn-secondary" onclick="closeUploadModal()">取消</button>
<button class="btn btn-primary" onclick="selectFile()">选择文件</button>
</div>
</div>
<div class="upload-progress" id="uploadProgress"><p>⏳ 上传中...</p></div>
<div class="upload-result" id="uploadResult">
<div class="preview-box" id="resultPreviewBox"></div>
<div style="margin-bottom:6px;font-size:13px;color:#6b6f86">📋 短链接集合：</div>
<div class="links-box" id="resultLinks"></div>
<div class="actions">
<button class="btn btn-copy" onclick="copyAllLinks()">📋 复制全部</button>
<button class="btn btn-secondary" onclick="closeUploadModal()">关闭</button>
</div>
</div>
</div>
</div>

<div class="toast" id="toast"></div>

<script>
var allIcons = [];
var pendingFile = null;
var currentCategory = "all";

function loadIcons() {
  fetch("/api/icons").then(function(r){return r.json()}).then(function(data){
    allIcons = data.icons || [];
    renderIcons(allIcons);
    renderFooterLinks();
  }).catch(function(){
    document.getElementById("iconGrid").innerHTML = '<div class="empty">😅 加载失败</div>';
  });
}

// 分类按钮
document.getElementById("folderGrid").addEventListener("click", function(e){
  var btn = e.target.closest(".folder-btn");
  if(!btn) return;
  document.querySelectorAll(".folder-btn").forEach(function(b){b.classList.remove("active")});
  btn.classList.add("active");
  currentCategory = btn.getAttribute("data-category");
  filterIcons();
});

function getFilteredIcons(){
  var q = document.getElementById("searchInput").value.toLowerCase();
  var result = [];
  for(var i=0;i<allIcons.length;i++){
    var ic = allIcons[i];
    // Category filter
    if(currentCategory !== "all"){
      var s = ic.shape || "square";
      // transparent icons may have shape "square" in some datasets, match by url path
      var url = ic.url || ic.short_url || "";
      if(currentCategory === "transparent" && s !== "transparent" && url.indexOf("/transparent/") < 0) continue;
      if(currentCategory === "circle" && s !== "circle") continue;
      if(currentCategory === "square" && s !== "square" && url.indexOf("/square/") < 0) continue;
      if(currentCategory === "square" && url.indexOf("/transparent/") >= 0) continue;
    }
    // Search filter
    if(q){
      var n = (ic.name||"").toLowerCase();
      var f = (ic.filename||"").toLowerCase();
      if(n.indexOf(q)<0 && f.indexOf(q)<0) continue;
    }
    result.push(ic);
  }
  return result;
}

function filterIcons(){
  renderIcons(getFilteredIcons());
}

function renderIcons(icons){
  var grid = document.getElementById("iconGrid");
  grid.textContent = "";
  if(!icons.length){
    var e = document.createElement("div");
    e.className = "empty";
    e.textContent = "🌸 暂无图标";
    grid.appendChild(e);
    return;
  }
  var frag = document.createDocumentFragment();
  for(var i=0;i<icons.length;i++){
    var ic = icons[i];
    var url = ic.short_url || ic.url || "https://cdn.jsdelivr.net/gh/buleeee1111/embytb/icons/"+ic.filename;
    var name = ic.name || ic.filename;
    var shape = ic.shape || "square";
    var safe = name.replace(/[^a-zA-Z0-9_-]/g,"_");

    var card = document.createElement("div");
    card.className = "icon-card " + shape;

    var img = document.createElement("img");
    img.src = url;
    img.alt = name;
    img.loading = "lazy";
    img.onerror = function(){this.style.display="none"};
    card.appendChild(img);

    var nd = document.createElement("div");
    nd.className = "name";
    nd.textContent = name;
    card.appendChild(nd);

    var badge = document.createElement("div");
    badge.className = "badge";
    badge.id = "bd-"+safe;
    badge.textContent = "已复制";
    card.appendChild(badge);

    card.onclick = (function(u,nm){
      return function(){
        navigator.clipboard.writeText(u).then(function(){
          var el = document.getElementById("bd-"+nm.replace(/[^a-zA-Z0-9_-]/g,"_"));
          if(el){el.classList.add("show");setTimeout(function(){el.classList.remove("show")},1500)}
          showToast("✅ 已复制短链接");
        }).catch(function(){showToast("复制失败")});
      };
    })(url,name);

    frag.appendChild(card);
  }
  grid.appendChild(frag);
}

// Footer links
function renderFooterLinks(){
  var el = document.getElementById("footerLinks");
  var cnt = document.getElementById("footerCount");
  el.textContent = "";
  if(!allIcons.length){
    el.innerHTML = '<span class="loading" style="padding:0;color:#6b6f86;font-size:12px">暂无图标</span>';
    return;
  }
  cnt.textContent = allIcons.length;
  var frag = document.createDocumentFragment();
  var lines = [];
  for(var i=0;i<allIcons.length;i++){
    var ic = allIcons[i];
    var u = ic.short_url || ic.url || "";
    var n = ic.name || ic.filename || "";
    var a = document.createElement("a");
    a.href = u;
    a.target = "_blank";
    a.title = n;
    a.textContent = u;
    frag.appendChild(a);
    lines.push(u);
  }
  el.appendChild(frag);
  _footerLinksText = lines.join("\\n");
}

var _footerLinksText = "";
function copyFooterAll(){
  if(!_footerLinksText){showToast("没有链接");return}
  navigator.clipboard.writeText(_footerLinksText).then(function(){showToast("✅ 已复制全部短链接")}).catch(function(){showToast("复制失败")});
}

// Upload modal
function openUploadModal(){
  document.getElementById("uploadForm").style.display="block";
  document.getElementById("uploadResult").classList.remove("show");
  document.getElementById("uploadProgress").classList.remove("show");
  document.getElementById("uploadModal").classList.add("show");
}
function closeUploadModal(){
  document.getElementById("uploadModal").classList.remove("show");
  document.getElementById("uploadResult").classList.remove("show");
  document.getElementById("uploadProgress").classList.remove("show");
  document.getElementById("uploadForm").style.display="block";
  pendingFile=null;
}
function selectFile(){document.getElementById("fileInput").click()}
document.getElementById("fileInput").addEventListener("change",function(e){
  if(this.files&&this.files[0]){pendingFile=this.files[0];doUpload()}
});
function handleDrop(e){
  e.preventDefault();document.getElementById("uploadArea").classList.remove("dragover");
  if(e.dataTransfer.files&&e.dataTransfer.files[0]){pendingFile=e.dataTransfer.files[0];openUploadModal();doUpload()}
}

function doUpload(){
  var nameInput=document.getElementById("iconNameInput");
  var iconName=nameInput.value.trim();
  if(!pendingFile){showToast("请选择文件");return}
  if(pendingFile.size>5*1024*1024){showToast("文件超过5MB");closeUploadModal();return}
  document.getElementById("uploadForm").style.display="none";
  document.getElementById("uploadProgress").classList.add("show");
  var fd=new FormData();
  fd.append("file",pendingFile,pendingFile.name);
  if(iconName)fd.append("icon_name",iconName);
  /* shape removed */
  fetch("/api/upload",{method:"POST",body:fd}).then(function(r){return r.json()}).then(function(data){
    if(data.success){
      document.getElementById("uploadProgress").classList.remove("show");
      document.getElementById("uploadResult").classList.add("show");
      var pb=document.getElementById("resultPreviewBox");pb.textContent="";
      var ri=document.createElement("img");ri.src=data.cdn_url;pb.appendChild(ri);
      var rd=document.createElement("div");rd.className="info";
      var rn=document.createElement("div");rn.className="nm";rn.textContent=data.name;rd.appendChild(rn);
      var ru=document.createElement("div");ru.className="url";ru.textContent=data.short_url||"";rd.appendChild(ru);
      pb.appendChild(rd);
      document.getElementById("resultLinks").textContent=data.all_links||"";
      window._lastAllLinks=data.all_links;
      nameInput.value="";pendingFile=null;
      loadIcons();
    }else{showToast(data.error||"上传失败");closeUploadModal()}
  }).catch(function(){showToast("上传失败，请重试");closeUploadModal()});
}

function copyAllLinks(){
  var t=window._lastAllLinks||"";
  if(!t){showToast("没有可复制的链接");return}
  navigator.clipboard.writeText(t).then(function(){showToast("✅ 已复制全部链接")}).catch(function(){showToast("复制失败")});
}

function showToast(msg){
  var t=document.getElementById("toast");t.textContent=msg;t.classList.add("show");
  setTimeout(function(){t.classList.remove("show")},2500);
}

// Drag events
document.getElementById("uploadArea").addEventListener("dragover",function(e){e.preventDefault();this.classList.add("dragover")});
document.getElementById("uploadArea").addEventListener("dragleave",function(){this.classList.remove("dragover")});
document.getElementById("uploadArea").addEventListener("drop",handleDrop);

loadIcons();
</script>
</body>
</html>"""

def run():
    server = HTTPServer(("0.0.0.0", PORT), EmbyTBHandler)
    print(f"")
    print(f"  embytb ACG Server")
    print(f"  http://0.0.0.0:{PORT}")
    print(f"  https://github.com/{OWNER}/{REPO}")
    print(f"")
    server.serve_forever()

if __name__ == "__main__":
    run()