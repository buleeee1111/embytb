.field input{width:100%;padding:12px;border-radius:14px;border:1px solid rgba(140,160,210,.28);background:rgba(255,255,255,.78);color:#2b2d3a;font-size:14px;outline:none;transition:.2s}
.field input:focus{border-color:rgba(124,107,255,.55);box-shadow:0 0 0 4px rgba(124,107,255,.16),0 10px 26px rgba(57,213,255,.1);transform:translateY(-1px)}
.btn{width:100%;border:none;border-radius:16px;padding:13px;font-size:16px;font-weight:700;cursor:pointer;color:#fff;background:linear-gradient(90deg,#ff6bd6,#7c6bff,#39d5ff);box-shadow:0 16px 28px rgba(124,107,255,.2),0 10px 18px rgba(255,107,214,.12);transition:.2s}
