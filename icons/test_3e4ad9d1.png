.stats-box{background:rgba(255,255,255,.72);backdrop-filter:blur(14px);border:1px solid rgba(255,255,255,.55);border-radius:22px;padding:20px 24px;margin-bottom:16px;box-shadow:0 18px 40px rgba(35,50,90,.12)}
.stats-box .num{font-size:28px;font-weight:700;background:linear-gradient(90deg,#ff6bd6,#7c6bff);-webkit-background-clip:text;background-clip:text;color:transparent}
.stats-box .label{font-size:13px;color:#6b6f86;margin-top:2px}
.search-box{background:rgba(255,255,255,.72);backdrop-filter:blur(14px);border:1px solid rgba(255,255,255,.55);border-radius:22px;padding:16px 20px;margin-bottom:16px;box-shadow:0 18px 40px rgba(35,50,90,.12)}
.search-box input{width:100%;padding:10px 14px;border-radius:14px;border:1px solid rgba(140,160,210,.28);background:rgba(255,255,255,.78);color:#2b2d3a;font-size:14px;outline:none;transition:.2s}
.search-box input:focus{border-color:rgba(124,107,255,.55);box-shadow:0 0 0 4px rgba(124,107,255,.16),0 10px 26px rgba(57,213,255,.1)}
.icon-list{display:flex;flex-direction:column;gap:10px}
