.login-box::before{content:"";position:absolute;inset:-120px -120px auto auto;width:260px;height:260px;background:radial-gradient(circle at 30% 30%,rgba(255,107,214,.35),transparent 60%),radial-gradient(circle at 70% 60%,rgba(57,213,255,.28),transparent 55%),radial-gradient(circle at 40% 80%,rgba(124,107,255,.25),transparent 60%);transform:rotate(12deg);pointer-events:none}
h1{text-align:center;margin-bottom:18px;font-size:24px;letter-spacing:.5px;background:linear-gradient(90deg,#ff6bd6,#7c6bff,#39d5ff);-webkit-background-clip:text;background-clip:text;color:transparent;position:relative}
