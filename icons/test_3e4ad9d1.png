background:radial-gradient(900px 600px at 12% 18%,rgba(255,107,214,.25),transparent 60%),radial-gradient(800px 520px at 85% 20%,rgba(57,213,255,.20),transparent 55%),radial-gradient(900px 650px at 55% 92%,rgba(124,107,255,.18),transparent 60%),linear-gradient(135deg,#ffe9f6,#e9f1ff,#eafff7)}
